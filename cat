<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CatTI - 猫咪人格测试 🐱</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background: linear-gradient(135deg, #ffecd2 0%, #fcb69f 100%);
            min-height: 100vh;
            padding: 20px;
            position: relative;
            overflow-x: hidden;
        }
        
        body::before {
            content: "🐾";
            position: fixed;
            top: 10%;
            left: 5%;
            font-size: 40px;
            opacity: 0.15;
            transform: rotate(-20deg);
        }
        body::after {
            content: "🐾";
            position: fixed;
            bottom: 15%;
            right: 8%;
            font-size: 50px;
            opacity: 0.15;
            transform: rotate(30deg);
        }
        
        .bg-paw {
            position: fixed;
            font-size: 35px;
            opacity: 0.12;
            pointer-events: none;
            z-index: 0;
        }
        
        .container {
            background: white;
            border-radius: 24px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
            max-width: 600px;
            width: 100%;
            margin: 0 auto;
            padding: 40px;
            text-align: center;
            position: relative;
            z-index: 1;
        }
        
        .logo {
            font-size: 64px;
            margin-bottom: 10px;
            animation: bounce 2s infinite;
        }
        
        @keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }
        
        h1 {
            font-size: 48px;
            color: #ff6b6b;
            margin-bottom: 10px;
            font-weight: 800;
        }
        
        .subtitle {
            color: #666;
            font-size: 16px;
            margin-bottom: 30px;
        }
        
        .progress-bar {
            width: 100%;
            height: 8px;
            background: #eee;
            border-radius: 4px;
            margin-bottom: 30px;
            overflow: hidden;
        }
        
        .progress {
            height: 100%;
            background: linear-gradient(90deg, #ff6b6b, #feca57);
            border-radius: 4px;
            transition: width 0.3s ease;
        }
        
        .page {
            display: none;
        }
        
        .page.active {
            display: block;
        }
        
        .question-page-decor {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-bottom: 20px;
            font-size: 28px;
        }
        
        .cat-face {
            animation: wiggle 1.5s infinite;
        }
        
        @keyframes wiggle {
            0%, 100% { transform: rotate(-5deg); }
            50% { transform: rotate(5deg); }
        }
        
        .question {
            font-size: 22px;
            color: #333;
            margin-bottom: 30px;
            line-height: 1.6;
            background: linear-gradient(135deg, #fff5f5 0%, #fff9e6 100%);
            padding: 25px;
            border-radius: 16px;
            border-left: 4px solid #ff6b6b;
        }
        
        .options {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }
        
        .option {
            padding: 20px;
            border: 2px solid #eee;
            border-radius: 16px;
            cursor: pointer;
            transition: all 0.2s ease;
            font-size: 16px;
            text-align: left;
            background: white;
            position: relative;
            overflow: hidden;
        }
        
        .option::before {
            content: "🐱";
            position: absolute;
            right: 15px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 20px;
            opacity: 0;
            transition: opacity 0.2s ease;
        }
        
        .option:hover {
            border-color: #ff6b6b;
            background: #fff5f5;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(255, 107, 107, 0.2);
        }
        
        .option:hover::before {
            opacity: 0.5;
        }
        
        .option.selected {
            border-color: #ff6b6b;
            background: #ff6b6b;
            color: white;
        }
        
        .option.selected::before {
            content: "✓";
            opacity: 1;
        }
        
        .start-btn, .restart-btn {
            background: linear-gradient(135deg, #ff6b6b 0%, #feca57 100%);
            color: white;
            border: none;
            padding: 18px 50px;
            font-size: 20px;
            border-radius: 50px;
            cursor: pointer;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
            font-weight: 600;
        }
        
        .start-btn:hover, .restart-btn:hover {
            transform: scale(1.05);
            box-shadow: 0 10px 30px rgba(255, 107, 107, 0.4);
        }
        
        .result-image {
            width: 150px;
            height: 150px;
            border-radius: 50%;
            object-fit: cover;
            margin-bottom: 20px;
            border: 4px solid #ff6b6b;
            box-shadow: 0 10px 30px rgba(255, 107, 107, 0.3);
            background: #f0f0f0;
        }
        
        .result-name {
            font-size: 32px;
            color: #ff6b6b;
            font-weight: 800;
            margin-bottom: 10px;
        }
        
        .result-subtitle {
            font-size: 18px;
            color: #666;
            margin-bottom: 20px;
        }
        
        .result-desc {
            text-align: left;
            background: #f8f8f8;
            padding: 25px;
            border-radius: 16px;
            margin-bottom: 20px;
            line-height: 1.8;
            color: #555;
        }
        
        .traits {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            justify-content: center;
            margin-bottom: 30px;
        }
        
        .trait {
            background: linear-gradient(135deg, #ffecd2 0%, #fcb69f 100%);
            padding: 8px 16px;
            border-radius: 20px;
            font-size: 14px;
            color: #333;
        }
        
        .dimension-scores {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            margin-bottom: 30px;
            text-align: left;
        }
        
        .dimension {
            background: #f8f8f8;
            padding: 15px;
            border-radius: 12px;
        }
        
        .dimension-label {
            font-size: 14px;
            color: #999;
            margin-bottom: 5px;
        }
        
        .dimension-value {
            font-size: 18px;
            font-weight: 600;
            color: #ff6b6b;
        }
        
        .share-tip {
            color: #999;
            font-size: 14px;
            margin-top: 20px;
        }
        
        .all-types-section {
            margin-top: 50px;
            padding-top: 40px;
            border-top: 2px dashed #eee;
        }
        
        .all-types-title {
            font-size: 24px;
            color: #ff6b6b;
            margin-bottom: 30px;
            font-weight: 700;
        }
        
        .all-types-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 20px;
            text-align: left;
        }
        
        .type-card {
            background: #f8f8f8;
            border-radius: 16px;
            padding: 20px;
            display: flex;
            gap: 20px;
            align-items: flex-start;
            transition: transform 0.2s ease;
        }
        
        .type-card:hover {
            transform: translateY(-3px);
        }
        
        .type-card.is-user {
            background: linear-gradient(135deg, #ffecd2 0%, #fcb69f 100%);
            border: 2px solid #ff6b6b;
        }
        
        .type-card-image {
            width: 80px;
            height: 80px;
            border-radius: 12px;
            object-fit: cover;
            flex-shrink: 0;
            background: #e0e0e0;
        }
        
        .type-card-content {
            flex: 1;
        }
        
        .type-card-header {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 8px;
        }
        
        .type-card-name {
            font-size: 20px;
            font-weight: 700;
            color: #333;
        }
        
        .type-card-subtitle {
            font-size: 14px;
            color: #888;
            margin-bottom: 10px;
        }
        
        .type-card-desc {
            font-size: 14px;
            color: #666;
            line-height: 1.7;
        }
        
        .your-result-badge {
            display: inline-block;
            background: #ff6b6b;
            color: white;
            font-size: 12px;
            padding: 3px 10px;
            border-radius: 10px;
            margin-left: 8px;
        }
        
        @media (max-width: 500px) {
            .dimension-scores {
                grid-template-columns: 1fr;
            }
            .type-card {
                flex-direction: column;
                align-items: center;
                text-align: center;
            }
            .type-card-content {
                text-align: left;
            }
        }
    </style>
</head>
<body>
    <div class="bg-paw" style="top: 25%; left: 15%;">🐾</div>
    <div class="bg-paw" style="top: 40%; right: 10%;">🐾</div>
    <div class="bg-paw" style="top: 60%; left: 8%;">🐾</div>
    <div class="bg-paw" style="top: 75%; right: 15%;">🐾</div>
