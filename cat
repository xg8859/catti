        本测试基于 MBTI 理论改编，通过 10 道精心设计的猫咪情境题目，帮你找到专属的<strong>猫格类型</strong>。<br><br>
        共有 <b>16 种猫格</b>等你发现，每种都有独特的性格画像~
      </div>
      <button class="start-btn" onclick="startQuiz()">开始测试 🐾</button>
      <div class="start-footer">灵感来自 DOGTI · Made with ❤️ for cats everywhere</div>
    </div>`;
}

function renderQuiz() {
  const q = QUESTIONS[currentQuestion];
  const selected = answers[currentQuestion];
  
  let dotsHtml = '';
  for(let i=0;i<QUESTIONS.length;i++){
    let cls = 'progress-dot';
    if(i===currentQuestion) cls+=' active';
    else if(i<currentQuestion || answers[i]!==undefined) cls+=' done';
    dotsHtml+=`<div class="${cls}"></div>`;
  }

  let optsHtml = '';
  q.options.forEach((opt, idx) => {
    const sel = selected === idx ? 'selected' : '';
    optsHtml += `
      <button class="option-btn ${sel}" onclick="selectOption(${idx})">
        <span class="option-text"><span class="option-label">${opt.label}</span>${opt.text}</span>
      </button>`;
  });

  const canNext = selected !== undefined;

  app.innerHTML = `
    <div class="quiz-page fade-in">
      <div class="progress-bar">${dotsHtml}</div>
      <div class="q-num">Q${currentQuestion+1} / ${QUESTIONS.length}</div>
      <div class="q-text">${q.text}</div>
      <div class="options">${optsHtml}</div>
      <div class="nav-row">
        ${currentQuestion > 0 ? `<button class="nav-btn nav-prev" onclick="prevQuestion()">← 上一题</button>` : '<span></span>'}
        <button class="nav-btn nav-next" onclick="nextQuestion()" ${canNext ? '' : 'disabled'}>${currentQuestion === QUESTIONS.length-1 ? '查看结果 🎉' : '继续 →'}</button>
      </div>
    </div>`;
}

function renderResult() {
  // 计算各维度分数
  const scores = [0,0,0,0]; // E, N, F, J 的总分
  answers.forEach(a => {
    if(a){
      for(let i=0;i<4;i++) scores[i] += a[i];
    }
  });

  // 判断每个维度的倾向
  let typeStr = '';
  const dimResults = [];
  // Q1: I/E → index 0, A=I(left), B=E(right)
  typeStr += scores[0]>=5 ? 'E' : 'I';
  dimResults.push({
    left: DIMENSIONS[0].leftName, right: DIMENSIONS[0].rightName,
    leftVal: 10-scores[0], rightVal: scores[0]
  });
  // Q2: S/N → index 1, A=S(left), B=N(right)
  typeStr += scores[1]>=5 ? 'N' : 'S';
  dimResults.push({
    left: DIMENSIONS[1].leftName, right: DIMENSIONS[1].rightName,
    leftVal: 10-scores[1], rightVal: scores[1]
  });
  // Q3: T/F → index 2, A=T(left), B=F(right)
  typeStr += scores[2]>=5 ? 'F' : 'T';
  dimResults.push({
    left: DIMENSIONS[2].leftName, right: DIMENSIONS[2].rightName,
    leftVal: 10-scores[2], rightVal: scores[2]
  });
  // Q4: P/J → index 3, A=J(right), B=P(left)
  typeStr += scores[3]>=5 ? 'J' : 'P';
  dimResults.push({
    left: DIMENSIONS[3].leftName, right: DIMENSIONS[3].rightName,
    leftVal: 10-scores[3], rightVal: scores[3]
  });

  const t = TYPES[typeStr];

  let barsHtml = '';
  dimResults.forEach((d,i) => {
    barsHtml+=`
      <div class="dbar">
        <div class="dbar-label"><span>${d.left}</span><span>${d.right}</span></div>
        <div class="dbar-track">
          <div class="dbar-fill left" style="width:${d.leftVal*10}%"></div>
          <div class="dbar-fill right" style="width:${d.rightVal*10}%"></div>
        </div>
      </div>`;
  });

  let tagsHtml = t.tags.map(tag=>`<span class="tag">#${tag}</span>`).join('');

  app.innerHTML = `
    <div class="result-page fade-in">
      <div class="result-emoji">${t.emoji}</div>
      <div class="result-type">${typeStr}</div>
      <div class="result-name">${t.name}</div>
      <div class="result-slogan">${t.slogan}</div>
      <div class="result-desc">${t.desc}</div>
      <div class="tags">${tagsHtml}</div>
      <div class="dimension-bars">${barsHtml}</div>
      <div class="result-actions">
        <button class="action-btn action-secondary" onclick="restartQuiz()">再测一次 🔄</button>
        <button class="action-btn action-primary" onclick="shareResult()">分享给朋友 📤</button>
      </div>
    </div>`;
}

// ========== 交互逻辑 ==========
function startQuiz(){
  page='quiz';currentQuestion=0;answers=[];
  renderQuiz();
}

function selectOption(idx){
  answers[currentQuestion]=idx;
  // 更新按钮状态
  const btns=document.querySelectorAll('.option-btn');
  btns.forEach((b,i)=>b.classList.toggle('selected',i===idx));
  // 启用下一步
  const nextBtn=document.querySelector('.nav-next');
  if(nextBtn){nextBtn.disabled=false;}
}

function nextQuestion(){
  if(currentQuestion < QUESTIONS.length-1){
    currentQuestion++;
    renderQuiz();
  } else {
    page='result';
    renderResult();
  }
}

function prevQuestion(){
  if(currentQuestion > 0){
    currentQuestion--;
    renderQuiz();
  }
}

function restartQuiz(){
  page='start';
  renderStart();
}

function shareResult(){
  const typeEl=document.querySelector('.result-type');
  const nameEl=document.querySelector('.result-name');
  if(typeEl&&nameEl){
    const text=`🐱 我的猫格是 ${typeEl.textContent} —— ${nameEl.textContent}！来测测你是什么猫吧~`;
    if(navigator.share){
      navigator.share({title:'CATTI 猫格人格测试',text:text,url:location.href}).catch(()=>{});
    }else{
      navigator.clipboard.writeText(text+' '+location.href).then(()=>{
        alert('已复制到剪贴板，快去粘贴分享吧！📋');
      }).catch(()=>{
        prompt('复制以下内容分享给朋友：',text+' '+location.href);
      });
    }
  }
}

// ========== 初始化 ==========
renderStart();
</script>
</body>
</html>
