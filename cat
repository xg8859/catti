<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CATTI — 猫格人格测试 🐱</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{
  font-family:-apple-system,BlinkMacSystemFont,'Segoe UI','PingFang SC','Hiragino Sans GB',sans-serif;
  background:#fef7f0;
  min-height:100vh;
  display:flex;align-items:center;justify-content:center;
  color:#333;
  overflow-x:hidden;
}
.container{
  width:100%;max-width:480px;min-height:100vh;padding:20px;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
}

/* ===== Start Page ===== */
.start-page{text-align:center}
.start-page .logo{font-size:72px;margin-bottom:8px}
.start-page h1{font-size:36px;font-weight:800;color:#2d1b0e;margin-bottom:4px;letter-spacing:-1px}
.start-page .subtitle{color:#a67c52;font-size:15px;margin-bottom:32px;font-weight:500}
.start-page .desc{color:#888;font-size:14px;line-height:1.8;margin-bottom:40px;text-align:left;background:#fff9f3;border-radius:16px;padding:24px 28px;border:1px solid #f0ddd0}
.start-btn{
  display:inline-block;padding:18px 56px;font-size:18px;font-weight:700;
  color:#fff;background:linear-gradient(135deg,#ff8c5a,#e86a3a);
  border:none;border-radius:50px;cursor:pointer;
  transition:all .3s ease;box-shadow:0 6px 24px rgba(232,106,58,.35);
  letter-spacing:2px;
}
.start-btn:hover{transform:translateY(-2px);box-shadow:0 10px 30px rgba(232,106,58,.45)}
.start-footer{margin-top:48px;color:#bbb;font-size:12px}

/* ===== Quiz Page ===== */
.quiz-page{width:100%}
.progress-bar{display:flex;gap:6px;margin-bottom:32px;justify-content:center}
.progress-dot{width:10px;height:10px;border-radius:50%;background:#f0ddd0;transition:.3s}
.progress-dot.active{background:#e86a3a;width:28px;border-radius:5px}
.progress-dot.done{background:#ffc099}
.q-num{font-size:13px;color:#bbb;text-align:center;margin-bottom:16px;font-weight:600;letter-spacing:2px}
.q-text{font-size:19px;color:#2d1b0e;line-height:1.7;text-align:center;margin-bottom:36px;font-weight:700;min-height:80px;display:flex;align-items:center;justify-content:center;padding:0 8px}
.options{display:flex;flex-direction:column;gap:14px}
.option-btn{
  padding:18px 22px;border:2px solid #f0ddd0;border-radius:16px;
  background:#fff;font-size:15px;color:#555;cursor:pointer;
  transition:all .25s ease;text-align:left;position:relative;
  font-weight:500;line-height:1.5;
}
.option-btn:hover{border-color:#ffb088;background:#fffaf7;transform:translateX(4px)}
.option-btn.selected{border-color:#e86a3a;background:#fff5ef;color:#c44d22}
.option-label{display:inline-block;width:30px;height:30px;line-height:30px;text-align:center;
  border-radius:50%;background:#f5ebe0;color:#a67c52;font-weight:800;font-size:13px;margin-right:12px;flex-shrink:0}
.option-btn.selected .option-label{background:#e86a3a;color:#fff}
.option-text{display:inline-flex;align-items:center}
.nav-row{display:flex;justify-content:space-between;align-items:center;margin-top:32px;padding-top:16px}
.nav-btn{
  padding:12px 28px;border:none;border-radius:50px;cursor:pointer;
  font-size:14px;font-weight:700;transition:all .3s;
}
.nav-prev{background:none;color:#bbb;border:2px solid #eee}
.nav-next{padding:14px 36px;color:#fff;background:linear-gradient(135deg,#ff8c5a,#e86a3a);box-shadow:0 4px 16px rgba(232,106,58,.3)}
.nav-next:hover{transform:translateY(-1px)}
.nav-next:disabled{opacity:.4;cursor:not-allowed;transform:none;box-shadow:none}

/* ===== Result Page ===== */
.result-page{text-align:center}
.result-emoji{font-size:80px;margin-bottom:12px;animation:bounceIn .8s ease}
@keyframes bounceIn{0%{transform:scale(0);opacity:0}60%{transform:scale(1.15)}100%{transform:scale(1);opacity:1}}
.result-type{font-size:42px;font-weight:900;color:#2d1b0e;margin-bottom:4px;letter-spacing:2px}
.result-name{font-size:26px;font-weight:800;color:#e86a3a;margin-bottom:8px}
.result-slogan{color:#a67c52;font-size:15px;margin-bottom:28px;font-style:italic}
.result-desc{color:#666;font-size:14px;line-height:2;text-align:left;background:#fff9f3;border-radius:16px;padding:24px 28px;margin-bottom:28px;border:1px solid #f0ddd0}
.tags{display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:36px}
.tag{padding:8px 18px;border-radius:20px;font-size:13px;font-weight:600;background:#fff5ef;color:#c47d4d;border:1px solid #f0ddd0}
.dimension-bars{width:100%;text-align:left;background:#fff;border-radius:16px;padding:24px 28px;margin-bottom:32px;border:1px solid #f0ddd0}
.dbar{margin-bottom:18px}
.dbar:last-child{margin-bottom:0}
.dbar-label{display:flex;justify-content:space-between;font-size:13px;font-weight:700;color:#888;margin-bottom:6px}
.dbar-track{height:8px;background:#f5ebe0;border-radius:4px;overflow:hidden;position:relative}
.dbar-fill{height:100%;border-radius:4px;transition:width 1s ease}
.dbar-fill.left{background:linear-gradient(90deg,#ffd6c4,#ffb088);float:left}
.dbar-fill.right{background:linear-gradient(90deg,#e86a3a,#c44d22);float:right}
.result-actions{display:flex;gap:14px;justify-content:center}
.action-btn{
  padding:14px 32px;border:none;border-radius:50px;cursor:pointer;
  font-size:15px;font-weight:700;transition:all .3s;
}
.action-primary{color:#fff;background:linear-gradient(135deg,#ff8c5a,#e86a3a);box-shadow:0 4px 16px rgba(232,106,58,.3)}
.action-secondary{color:#999;background:#f5ebe0;border:2px solid #f0ddd0}
.action-btn:hover{transform:translateY(-2px)}

/* ===== Animations ===== */
.fade-in{animation:fadeIn .45s ease}
@keyframes fadeIn{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
.slide-in{animation:slideIn .4s ease}
@keyframes slideIn{from{opacity:0;transform:translateX(24px)}to{opacity:1;transform:translateX(0)}}

/* ===== Responsive ===== */
@media(max-width:400px){
  .container{padding:16px}
  .start-page h1{font-size:28px}
  .q-text{font-size:17px}
  .option-btn{padding:14px 18px;font-size:14px}
  .result-type{font-size:34px}
}
</style>
</head>
