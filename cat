            </div>
            <p style="color: #999; margin-bottom: 10px;" id="question-num">问题 1/12</p>
            <div class="question" id="question-text"></div>
            <div class="options" id="options"></div>
        </div>
        
        <div id="result-page" class="page">
            <img class="result-image" id="result-image" src="" alt="">
            <div class="result-name" id="result-name"></div>
            <div class="result-subtitle" id="result-subtitle"></div>
            <div class="traits" id="traits"></div>
            <div class="result-desc" id="result-desc"></div>
            <div class="dimension-scores" id="dimension-scores"></div>
            <button class="restart-btn" onclick="restart()">再测一次 🔄</button>
            <p class="share-tip">截图分享给你的猫友吧~</p>
            
            <div class="all-types-section">
                <div class="all-types-title">🐱 全部 16 种猫咪人格</div>
                <div class="all-types-grid" id="all-types-grid"></div>
            </div>
        </div>
    </div>

    <script>
