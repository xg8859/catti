                traits: ["独特", "想象力丰富", "精灵气质", "活泼", "治愈系"]
            },
            "ISTJ": {
                name: "英国短毛猫",
                subtitle: "稳重的绅士",
                image: "https://cdn2.thecatapi.com/images/MTkyOTcwNQ.jpg",
                desc: "你是猫界的模范公民！稳重、可靠、有原则。你有固定的作息时间表，固定的吃饭地点，固定的睡觉位置。你圆圆的脸蛋和敦实的身材让人忍不住想捏，但你总是保持着绅士的风度。主人可以完全信任你——因为你从不惹麻烦。",
                traits: ["稳重", "可靠", "有原则", "自律", "绅士风度"]
            },
            "ISTP": {
                name: "俄罗斯蓝猫",
                subtitle: "高冷的酷盖",
                image: "https://cdn2.thecatapi.com/images/dLrzJVXo1.jpg",
                desc: "你是猫界的酷盖！冷静、独立、技术流。你不太需要主人的关注，自己就能玩得很开心。你擅长解决实际问题——开柜门、抓虫子、解谜题，这些都是小菜一碟。银蓝色的毛发和翠绿的眼睛让你看起来格外神秘，是最高冷的猫。",
                traits: ["高冷", "独立", "技术宅", "聪明", "神秘"]
            },
            "ISFJ": {
                name: "苏格兰折耳猫",
                subtitle: "温柔的小天使",
                image: "https://cdn2.thecatapi.com/images/15l.jpg",
                desc: "你是最让人心疼的猫——因为太懂事了！折下来的耳朵让你看起来格外温柔。你从不给主人添麻烦，总是默默付出。你喜欢安静的环境，享受和主人独处的时光。你对主人有着无条件的爱，即使被忽视也不会抱怨。",
                traits: ["温柔", "懂事", "忠诚", "安静", "默默付出"]
            },
            "ISFP": {
                name: "雪鞋猫",
                subtitle: "艺术的小精灵",
                image: "https://cdn2.thecatapi.com/images/8hh.jpg",
                desc: "你是猫界的艺术家！敏感、细腻、有独特的审美。白色的脚掌像穿着小靴子，优雅又可爱。你喜欢美好的事物——阳光、花香、柔软的毯子。你有着独特的气质，不需要刻意表现就能吸引眼球。你享受当下，是最会享受生活的猫。",
                traits: ["艺术气质", "敏感", "优雅", "享受生活", "独特"]
            },
            "INTJ": {
                name: "挪威森林猫",
                subtitle: "深邃的哲学家",
                image: "https://cdn2.thecatapi.com/images/bc6.jpg",
                desc: "你是猫界的哲学家！深邃、独立、有洞察力。厚实的毛发让你能适应任何环境，你喜欢独处，在安静中思考宇宙的奥秘（或者如何打开那个该死的柜子）。你不需要太多社交，但当你决定亲近某人时，那份感情是深沉而真挚的。",
                traits: ["深邃", "独立", "有洞察力", "战略思维", "神秘"]
            },
            "INTP": {
                name: "新加坡猫",
                subtitle: "聪明的学者",
                image: "https://cdn2.thecatapi.com/images/d80.png",
                desc: "你是猫界的学者！好奇、分析、永远在学习。虽然体型小巧，但智商爆表。你对世界充满疑问：为什么激光笔抓不到？为什么水会流动？你享受思考和探索的过程，是最聪明的猫之一。主人常觉得你在用眼神审视他——其实你只是在观察。",
                traits: ["聪明", "好奇", "分析型", "学者气质", "小巧精悍"]
            },
            "INFJ": {
                name: "土耳其梵猫",
                subtitle: "灵性的守护者",
                image: "https://cdn2.thecatapi.com/images/d8n.jpg",
                desc: "你是最有灵性的猫！直觉敏锐、洞察人心。你似乎能感知主人的情绪变化，在他需要时默默出现。你有着独特的梵猫花纹和深邃的眼神，仿佛藏着整个宇宙。你喜欢安静的环境，享受精神层面的连接，是最懂主人的猫。",
                traits: ["有灵性", "直觉强", "深沉", "善解人意", "治愈系"]
            },
            "INFP": {
                name: "安哥拉猫",
                subtitle: "浪漫的诗人",
                image: "https://cdn2.thecatapi.com/images/dkp.jpg",
                desc: "你是猫界的诗人！浪漫、敏感、活在自己的小世界里。丝滑的长毛随风飘动，像一位艺术家。你有着柔软的心，容易被触动。你喜欢追逐蝴蝶、凝望星空、在阳光下打盹做白日梦。你不需要太多物质，精神世界的富足才是你的追求。",
                traits: ["浪漫", "敏感", "梦幻", "温柔", "艺术气质"]
            }
        };

        const typeOrder = ["ESTJ", "ESTP", "ESFJ", "ESFP", "ENTJ", "ENTP", "ENFJ", "ENFP", "ISTJ", "ISTP", "ISFJ", "ISFP", "INTJ", "INTP", "INFJ", "INFP"];

        let currentQuestion = 0;
        let scores = { E: 0, I: 0, S: 0, N: 0, T: 0, F: 0, J: 0, P: 0 };

        function startTest() {
            document.getElementById('start-page').classList.remove('active');
            document.getElementById('question-page').classList.add('active');
            showQuestion(0);
        }

        function showQuestion(index) {
            const question = questions[index];
            document.getElementById('question-num').textContent = `问题 ${index + 1}/${questions.length}`;
            document.getElementById('progress').style.width = `${((index + 1) / questions.length) * 100}%`;
            document.getElementById('question-text').textContent = question.text;
            
            const optionsDiv = document.getElementById('options');
            optionsDiv.innerHTML = '';
            
            question.options.forEach((option, i) => {
                const btn = document.createElement('div');
                btn.className = 'option';
                btn.textContent = option.text;
                btn.onclick = () => selectOption(i, option.scores);
                optionsDiv.appendChild(btn);
            });
        }

        function selectOption(optionIndex, optionScores) {
            for (const [dimension, score] of Object.entries(optionScores)) {
                scores[dimension] += score;
            }
            
            const options = document.querySelectorAll('.option');
            options[optionIndex].classList.add('selected');
            
            setTimeout(() => {
                currentQuestion++;
                if (currentQuestion < questions.length) {
                    showQuestion(currentQuestion);
                } else {
                    showResult();
                }
            }, 300);
        }

        function showResult() {
            document.getElementById('question-page').classList.remove('active');
            document.getElementById('result-page').classList.add('active');
            
            const type = 
                (scores.E >= scores.I ? 'E' : 'I') +
                (scores.S >= scores.N ? 'S' : 'N') +
                (scores.T >= scores.F ? 'T' : 'F') +
                (scores.J >= scores.P ? 'J' : 'P');
            
            const result = results[type];
            
            document.getElementById('result-image').src = result.image;
            document.getElementById('result-name').textContent = result.name;
            document.getElementById('result-subtitle').textContent = result.subtitle;
            document.getElementById('result-desc').textContent = result.desc;
            
            const traitsDiv = document.getElementById('traits');
            traitsDiv.innerHTML = '';
            result.traits.forEach(trait => {
                const span = document.createElement('span');
                span.className = 'trait';
                span.textContent = trait;
                traitsDiv.appendChild(span);
            });
            
            const dimensionsDiv = document.getElementById('dimension-scores');
            dimensionsDiv.innerHTML = `
                <div class="dimension">
                    <div class="dimension-label">能量来源</div>
                    <div class="dimension-value">${scores.E >= scores.I ? 'E 外向' : 'I 内向'} (${Math.max(scores.E, scores.I)})</div>
                </div>
                <div class="dimension">
                    <div class="dimension-label">认知方式</div>
                    <div class="dimension-value">${scores.S >= scores.N ? 'S 感觉' : 'N 直觉'} (${Math.max(scores.S, scores.N)})</div>
                </div>
                <div class="dimension">
                    <div class="dimension-label">决策方式</div>
                    <div class="dimension-value">${scores.T >= scores.F ? 'T 思考' : 'F 情感'} (${Math.max(scores.T, scores.F)})</div>
                </div>
                <div class="dimension">
                    <div class="dimension-label">生活态度</div>
                    <div class="dimension-value">${scores.J >= scores.P ? 'J 判断' : 'P 知觉'} (${Math.max(scores.J, scores.P)})</div>
                </div>
            `;
            
            renderAllTypes(type);
        }
        
        function renderAllTypes(userType) {
            const grid = document.getElementById('all-types-grid');
            grid.innerHTML = '';
            
            typeOrder.forEach(typeCode => {
                const r = results[typeCode];
                const isUser = typeCode === userType;
                
                const card = document.createElement('div');
                card.className = 'type-card' + (isUser ? ' is-user' : '');
                card.innerHTML = `
                    <img class="type-card-image" src="${r.image}" alt="${r.name}">
                    <div class="type-card-content">
                        <div class="type-card-header">
                            <span class="type-card-name">${r.name}${isUser ? '<span class="your-result-badge">你的结果</span>' : ''}</span>
                        </div>
                        <div class="type-card-subtitle">${r.subtitle}</div>
                        <div class="type-card-desc">${r.desc}</div>
                    </div>
                `;
                grid.appendChild(card);
            });
        }

        function restart() {
            currentQuestion = 0;
            scores = { E: 0, I: 0, S: 0, N: 0, T: 0, F: 0, J: 0, P: 0 };
            document.getElementById('result-page').classList.remove('active');
            document.getElementById('start-page').classList.add('active');
        }
    </script>
</body>
</html>
